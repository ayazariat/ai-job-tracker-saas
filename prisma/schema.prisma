generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
  cvVersions   CvVersion[]

  @@map("users")
}

model Application {
  id          String            @id @default(cuid())
  userId      String
  company     String
  role        String
  status      ApplicationStatus @default(WISHLIST)
  appliedAt   DateTime?
  deadline    DateTime?
  notes       String?           @db.Text
  salaryRange String?
  source      String?
  url         String?           @db.Text
  order       Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminders   Reminder[]
  aiMatches   AiMatch[]

  @@index([userId, status])
  @@map("applications")
}

enum ApplicationStatus {
  WISHLIST
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
}

model Reminder {
  id            String      @id @default(cuid())
  applicationId String
  type          ReminderType
  sendAt        DateTime
  sent          Boolean     @default(false)
  sentAt        DateTime?
  message       String?      @db.Text
  createdAt     DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([sendAt, sent])
  @@map("reminders")
}

enum ReminderType {
  FOLLOW_UP
  INTERVIEW
  DEADLINE
}

model CvVersion {
  id        String    @id @default(cuid())
  userId    String
  name      String
  content   String    @db.LongText
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiMatches AiMatch[]

  @@map("cv_versions")
}

model AiMatch {
  id              String       @id @default(cuid())
  applicationId   String?
  cvVersionId     String
  matchScore      Float
  missingSkills   Json
  keywords        Json
  insights        String?      @db.Text
  jobDescription  String       @db.Text
  createdAt       DateTime     @default(now())
  application     Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  cvVersion       CvVersion    @relation(fields: [cvVersionId], references: [id], onDelete: Cascade)

  @@map("ai_matches")
}
